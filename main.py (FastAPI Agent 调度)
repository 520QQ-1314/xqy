@app.post("/api/v1/agent/product-master")
async def agent_product_master(
    file: UploadFile = File(...),
    prompt: str = Form("Minimalist studio background"),
    mode: str = Form("generate_scene") # modes: generate_scene, rembg, outpaint
):
    """核心智能体端口：处理抠图、扩图、图生图场景"""
    
    task_id = str(uuid.uuid4())
    input_path = os.path.join(UPLOAD_FOLDER, f"{task_id}_input.png")
    
    # 保存上传图片
    with open(input_path, "wb") as f:
        f.write(await file.read())

    # Agent 根据模式执行不同的工具流
    
    if mode == "rembg":
        """工具流 1: 自动抠图 (使用开源或 API)"""
        print(f"Agent [{task_id}]: 正在执行抠图...")
        # 实际代码中调用 rembg 库或 API
        # res = requests.post(REM_BG_API_ENDPOINT, files={'image_file': open(input_path, 'rb')}, headers={'X-Api-Key': INTERNAL_REMBG_KEY})
        # with open(output_path, 'wb') as f: f.write(res.content)
        result_url = "https://cdn-icons-png.flaticon.com/512/3593/3593302.png" # 模拟抠图结果
        return {"status": "success", "task_id": task_id, "output_url": result_url, "type": "rembg"}

    elif mode == "generate_scene":
        """工具流 2: 精准控图图生图 (产品重绘场景)"""
        print(f"Agent [{task_id}]: 正在执行图生图...")
        # 调用 Nanobanana 2 的 Image-to-Image 接口，带 ControlNet 约束
        payload = {
            "model": "nano-banana-2",
            "init_image_path": f"user_uploads/{task_id}_input.png", # 假设你上传到了他们的 CDN
            "prompt": f"Professional e-commerce photography of the product, {prompt}, soft lighting, minimalist, 8k",
            "control_type": "canny", # 精准控图
            "denoising_strength": 0.5
        }
        # response = requests.post(NB_API_ENDPOINT, json=payload, headers={"Authorization": f"Bearer {INTERNAL_NANOBANANA_KEY}"})
        result_url = "https://images.unsplash.com/photo-1578474846511-04ba529f0b88" # 模拟生成结果
        return {"status": "success", "task_id": task_id, "output_url": result_url, "type": "img2img"}

    elif mode == "outpaint":
        """工具流 3: 扩图 (Outpainting)"""
        print(f"Agent [{task_id}]: 正在执行扩图...")
        # 这通常需要 SD 模型的扩图功能
        payload = {
            "prompt": f"seamlessly extended background, {prompt}",
            "init_image": "...",
            "mask_mode": "inpaint_outpaint"
        }
        result_url = "https://images.unsplash.com/photo-1523275335684-37898b6baf30" # 模拟扩图结果
        return {"status": "success", "task_id": task_id, "output_url": result_url, "type": "outpaint"}

    raise HTTPException(status_code=400, detail="Invalid Agent Mode")

